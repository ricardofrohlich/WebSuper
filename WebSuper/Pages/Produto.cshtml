@page
@model WebSuper.Pages.ProdutoModel
@{
    ViewData["Title"] = "Cadastro de Produto";
}
<h2>@ViewData["Title"]</h2>
<table style="border-collapse: collapse; width: 100%;">
    <thead>
        <tr>
            <th style="border: 1px solid black; padding: 8px;">Nome</th>
            <th style="border: 1px solid black; padding: 8px;">Preço</th>
            <th style="border: 1px solid black; padding: 8px;">Estoque</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var produto in Model.Produtos)
        {
            <tr>
                <td style="border: 1px solid black; padding: 8px;">@produto.Nome</td>
                <td style="border: 1px solid black; padding: 8px;">@produto.Preco.ToString("C")</td>
                <td style="border: 1px solid black; padding: 8px;">@produto.Estoque</td>
            </tr>
        }
        </tbody>
</table>



